# Copy to .env and adjust (optional).

# -----------------------------------------------------------------------------
# Local external test-server
# -----------------------------------------------------------------------------

# Where your `bun run test-server` is listening (host:port).
TEST_SERVER_BASE_URL=127.0.0.1:50051

# -----------------------------------------------------------------------------
# Timeouts (milliseconds)
# -----------------------------------------------------------------------------

# Per-test timeout (Vitest).
TEST_TIMEOUT=30000

# Hook timeout (Vitest).
HOOK_TIMEOUT=30000

# Whole test-run watchdog. Set 0 to disable.
RUN_TIMEOUT=120000

# Default timeouts for expect.poll(...).
EXPECT_POLL_TIMEOUT=1000
EXPECT_POLL_INTERVAL=50

# -----------------------------------------------------------------------------
# gRPC rate limiting (optional)
# -----------------------------------------------------------------------------
#
# Use these when pointing at real services that enforce quotas.
# Values are per-process (so CI jobs/workers still run independently).
#
# GRPC_RATE_LIMIT_RPS=10
# GRPC_RATE_LIMIT_BURST=10
# GRPC_MAX_INFLIGHT=5
# GRPC_RATE_LIMIT_LEASE_TIMEOUT_MS=60000

# Playwright (UI).
PLAYWRIGHT_BASE_URL=https://example.com
PLAYWRIGHT_TEST_TIMEOUT=60000
PLAYWRIGHT_EXPECT_TIMEOUT=10000
PLAYWRIGHT_ACTION_TIMEOUT=60000
PLAYWRIGHT_RETRIES=0

# Retries (Vitest). Set 0 for local runs.
VITEST_RETRY=0

# -----------------------------------------------------------------------------
# Reporting
# -----------------------------------------------------------------------------

# JUnit XML output file (Vitest junit reporter).
JUNIT_OUTPUT_FILE=test-results/junit.xml

# Allure results directory (allure-vitest reporter).
ALLURE_RESULTS_DIR=allure-results-api

# Optional: Allure results dir for Playwright runs (for later merge).
# If unset, Playwright defaults to `allure-results-ui`.
ALLURE_RESULTS_DIR_UI=allure-results-ui

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Log level: debug | info | warn | error | silent
# LOG_LEVEL=debug
