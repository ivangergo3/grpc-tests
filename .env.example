# Copy to .env and adjust. Used for local/dev test runs.

# -----------------------------------------------------------------------------
# Test environment: local (stub servers) | dev (deployed services)
# -----------------------------------------------------------------------------
TEST_ENV=local

# -----------------------------------------------------------------------------
# Multi-response / streaming (SendEmailStream, GetStockAggregated)
# System A = always on. B and C = optional. Expected response count: 1, 2, or 3.
# Set to "true" or "1" to enable. Leave empty or unset for 1 response.
# -----------------------------------------------------------------------------

# 1 response (default) – System A only
# SYSTEM_B_ENABLED=
# SYSTEM_C_ENABLED=

# 2 responses – System A + B (uncomment to test)
# SYSTEM_B_ENABLED=1
# SYSTEM_C_ENABLED=

# 3 responses – System A + B + C (uncomment to test)
# SYSTEM_B_ENABLED=1
# SYSTEM_C_ENABLED=1

SYSTEM_B_ENABLED=
SYSTEM_C_ENABLED=

# -----------------------------------------------------------------------------
# Optional: gRPC and logging
# -----------------------------------------------------------------------------

# Base host:port for gRPC targets (e.g. my-namespace.svc.cluster.local:443)
# GRPC_BASE_URL=

# Log level: debug | info | warn | error | silent
# LOG_LEVEL=debug

# gRPC default deadline (ms). Override per call if needed.
# GRPC_DEFAULT_DEADLINE_MS=5000

# Per-call TLS (when not using full env config in environments.ts)
# GRPC_TARGET=host:port
# GRPC_INSECURE=false
# GRPC_CA_CERT_PATH=
# GRPC_CLIENT_CERT_PATH=
# GRPC_CLIENT_KEY_PATH=
