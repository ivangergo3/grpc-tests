# Copy to .env and adjust (optional).

# -----------------------------------------------------------------------------
# Local external test-server
# -----------------------------------------------------------------------------

# Where your `bun run test-server` is listening (host:port).
TEST_SERVER_BASE_URL=127.0.0.1:50051

# -----------------------------------------------------------------------------
# Timeouts (ms)
# -----------------------------------------------------------------------------

# Per-test timeout (Vitest).
TEST_TIMEOUT_MS=30000

# Hook timeout (Vitest).
HOOK_TIMEOUT_MS=30000

# Whole test-run watchdog. Set 0 to disable.
RUN_TIMEOUT_MS=120000

# Retries (Vitest). Set 0 for local runs.
VITEST_RETRY=0

# Default timeouts for expect.poll(...) (ms).
EXPECT_POLL_TIMEOUT_MS=1000
EXPECT_POLL_INTERVAL_MS=50

# JUnit XML output file (Vitest junit reporter).
JUNIT_OUTPUT_FILE=test-results/junit.xml

# Allure results directory (allure-vitest reporter).
ALLURE_RESULTS_DIR=allure-results

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Log level: debug | info | warn | error | silent
# LOG_LEVEL=debug
